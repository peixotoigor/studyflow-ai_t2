{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build --workspace=studyflow-frontend",
  "outputDirectory": "apps/frontend/dist",
  "functions": {
    "api/**/*.ts": {
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
