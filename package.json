{
  "name": "studyflow-ai",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/backend",
    "apps/frontend"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm run dev --workspace=studyflow-backend",
    "dev:frontend": "npm run dev --workspace=studyflow-frontend",
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "npm run build --workspace=studyflow-backend",
    "build:frontend": "npm run build --workspace=studyflow-frontend",
    "start": "npm run start --workspace=studyflow-backend",
    "lint": "npm run lint --workspace=studyflow-backend",
    "test:setup": "node scripts/setup.cjs",
    "test:api": "node scripts/test-api.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
